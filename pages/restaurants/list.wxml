<view class="page" bindtap="onPageTap">
  <view class="header">
    <text class="title">全部饭局</text>

  </view>

  <view wx:if="{{restaurants.length === 0}}" class="empty-state">
    <text>尚无饭局记录，先回去获取天意。</text>
  </view>

  <scroll-view wx:else scroll-y class="restaurant-list">
    <view
      wx:for="{{restaurants}}"
      wx:key="blacklistKey"
      class="restaurant-card {{item.blacklisted ? 'blacklisted' : ''}}"
    >
      <view class="restaurant-main">
        <view class="restaurant-heading">
          <text class="restaurant-name">{{item.title}}</text>
          <text wx:if="{{item.blacklisted}}" class="blacklist-badge">黑名单</text>
        </view>
        <text wx:if="{{item.address}}" class="restaurant-address">{{item.address}}</text>
      </view>

      <view class="restaurant-facts">
        <view class="fact-row">
          <text class="fact-label">距离</text>
          <text class="fact-value">{{item.distance ? item.distance + 'm' : '未知'}}</text>
        </view>
        <view class="fact-row">
          <text class="fact-label">人均</text>
          <text class="fact-value">{{item.biz_ext && item.biz_ext.cost ? '¥' + item.biz_ext.cost + '/人' : '暂无'}}</text>
        </view>
        <view class="fact-row">
          <text class="fact-label">类别</text>
          <text class="fact-value">{{item.category || '暂无'}}</text>
        </view>
        <view class="fact-row">
          <text class="fact-label">星级</text>
          <text class="fact-value star">{{item.biz_ext && item.biz_ext.rating ? item.biz_ext.rating : '暂无'}}</text>
        </view>
      </view>

      <button
        class="blacklist-button {{item.blacklisted ? 'restore' : ''}}"
        hover-class="button-press"
        data-key="{{item.blacklistKey}}"
        bindtap="onToggleBlacklist"
      >
        {{item.blacklisted ? '枯木逢春' : '打入冷宫'}}
      </button>
    </view>
  </scroll-view>
</view>
