.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24px 18px;
  background:
    radial-gradient(circle at 14% 10%, rgba(52, 96, 118, 0.18), transparent 32%),
    radial-gradient(circle at 86% 22%, rgba(141, 49, 62, 0.18), transparent 34%),
    linear-gradient(180deg, #120f13 0%, #1d1214 52%, #080808 100%);
  color: #fff7df;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 18px;
}

.title {
  color: #f5ddaa;
  font-size: 28px;
  font-weight: 800;
  letter-spacing: 0;
}

.subtitle {
  color: #8fd1cb;
  font-size: 13px;
}

.empty-state {
  margin-top: 90px;
  padding: 18px;
  border: 1px solid rgba(143, 209, 203, 0.24);
  border-radius: 8px;
  background: rgba(18, 15, 19, 0.68);
  color: rgba(245, 221, 170, 0.78);
  font-size: 14px;
  text-align: center;
}

.restaurant-list {
  height: calc(100vh - 100px);
}

.restaurant-card {
  margin-bottom: 12px;
  padding: 14px;
  border: 1px solid rgba(245, 221, 170, 0.14);
  border-radius: 8px;
  background: rgba(18, 15, 19, 0.78);
  box-shadow: 0 8px 22px rgba(0, 0, 0, 0.18);
}

.restaurant-card.blacklisted {
  border-color: rgba(220, 108, 120, 0.34);
  background: rgba(42, 24, 28, 0.78);
}

.restaurant-main {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 12px;
}

.restaurant-heading {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.restaurant-name {
  flex: 1;
  color: #fff7df;
  font-size: 17px;
  font-weight: 700;
  line-height: 1.35;
}

.blacklist-badge {
  flex-shrink: 0;
  padding: 3px 8px;
  border-radius: 999px;
  background: rgba(220, 108, 120, 0.18);
  color: #dc6c78;
  font-size: 11px;
}

.restaurant-address {
  color: rgba(245, 221, 170, 0.56);
  font-size: 12px;
  line-height: 1.4;
}

.restaurant-facts {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.fact-row {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  font-size: 13px;
  line-height: 1.35;
}

.fact-label {
  width: 38px;
  flex-shrink: 0;
  color: rgba(143, 209, 203, 0.78);
}

.fact-value {
  flex: 1;
  color: rgba(255, 247, 223, 0.88);
}

.fact-value.star {
  color: #d7b878;
}

.blacklist-button {
  width: 100%;
  height: 42px;
  margin-top: 14px;
  border: none;
  border-radius: 8px;
  background: linear-gradient(135deg, #b83d45, #d99b50);
  color: #ffffff;
  font-size: 14px;
  font-weight: 700;
  line-height: 42px;
}

.blacklist-button.restore {
  background: linear-gradient(135deg, #267c7a, #3d6a58);
}

.blacklist-button::after {
  border: none;
}
