.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24px 18px;
  background:
    radial-gradient(circle at 14% 10%, rgba(201, 168, 76, 0.18), transparent 32%),
    radial-gradient(circle at 86% 22%, rgba(196, 74, 58, 0.18), transparent 34%),
    linear-gradient(180deg, #f5efdf 0%, #ede0c8 52%, #e0d0b0 100%);
  color: #2c2416;
}

.button-press {
  filter: brightness(0.86);
  transform: translateY(2px) scale(0.98);
  box-shadow: 0 2px 8px rgba(44, 36, 22, 0.22);
}

.header {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 18px;
}

.title {
  color: #2c2416;
  font-size: 28px;
  font-weight: 800;
  letter-spacing: 0;
}

.subtitle {
  color: #a8864a;
  font-size: 13px;
}

.empty-state {
  margin-top: 90px;
  padding: 18px;
  border: 1px solid rgba(168, 134, 74, 0.24);
  border-radius: 8px;
  background: rgba(44, 36, 22, 0.06);
  color: rgba(44, 36, 22, 0.52);
  font-size: 14px;
  text-align: center;
}

.restaurant-list {
  height: calc(100vh - 100px);
}

.restaurant-card {
  margin-bottom: 12px;
  padding: 14px;
  border: 1px solid rgba(44, 36, 22, 0.14);
  border-radius: 8px;
  background: rgba(44, 36, 22, 0.06);
  box-shadow: 0 8px 22px rgba(0, 0, 0, 0.08);
}

.restaurant-card.blacklisted {
  border-color: rgba(196, 74, 58, 0.34);
  background: rgba(196, 74, 58, 0.08);
}

.restaurant-main {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 12px;
}

.restaurant-heading {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.restaurant-name {
  flex: 1;
  color: #2c2416;
  font-size: 17px;
  font-weight: 700;
  line-height: 1.35;
}

.blacklist-badge {
  flex-shrink: 0;
  padding: 3px 8px;
  border-radius: 999px;
  background: rgba(196, 74, 58, 0.18);
  color: #c44a3a;
  font-size: 11px;
}

.restaurant-address {
  color: rgba(44, 36, 22, 0.56);
  font-size: 12px;
  line-height: 1.4;
}

.restaurant-facts {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.fact-row {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  font-size: 13px;
  line-height: 1.35;
}

.fact-label {
  width: 38px;
  flex-shrink: 0;
  color: rgba(168, 134, 74, 0.78);
}

.fact-value {
  flex: 1;
  color: rgba(44, 36, 22, 0.88);
}

.fact-value.star {
  color: #c9a84c;
}

.blacklist-button {
  width: 100%;
  height: 42px;
  margin-top: 14px;
  border: none;
  border-radius: 8px;
  background: linear-gradient(135deg, #2c2416, #7a6e64);
  color: #ffffff;
  font-size: 14px;
  font-weight: 700;
  line-height: 42px;
}

.blacklist-button.restore {
  background: linear-gradient(135deg, #8b6d3f, #a8864a);
}

.blacklist-button::after {
  border: none;
}
