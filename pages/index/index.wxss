/* ==================== 结果模态卡片 ==================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.modal-overlay.visible {
  opacity: 1;
  pointer-events: auto;
}

.result-card {
  width: 100%;
  max-width: 400px;
  background: #f5efdf;
  border-radius: 20px 20px 0 0;
  padding: 28px 24px 36px;
  position: relative;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.result-seal {
  position: absolute;
  top: -26px;
  right: 34px;
  z-index: 2;
  width: 58px;
  height: 58px;
  border-radius: 50%;
  background: rgba(196, 74, 58, 0.96);
  color: #f5efdf;
  border: 2px solid rgba(201, 168, 76, 0.62);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: bold;
  box-shadow: 0 8px 24px rgba(58, 23, 18, 0.38);
  animation: sealDrop 0.78s cubic-bezier(0.2, 0.9, 0.22, 1.25) both;
  pointer-events: none;
}

@keyframes sealDrop {
  0% {
    opacity: 0;
    transform: translateY(-22px) rotate(-16deg) scale(1.25);
  }
  55% {
    opacity: 1;
    transform: translateY(4px) rotate(4deg) scale(0.94);
  }
  100% {
    opacity: 0;
    transform: translateY(0) rotate(0deg) scale(1);
  }
}

.result-card.visible {
  transform: translateY(0);
}

.card-close {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: rgba(44, 36, 22, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: #999;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}

.card-emoji {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: rgba(168, 134, 74, 0.2);
  color: #f5efdf;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-title-group {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-kicker {
  font-size: 12px;
  color: #a8864a;
  margin-bottom: 3px;
}

.card-title {
  font-size: 22px;
  font-weight: bold;
  color: #2c2416;
  flex: 1;
}

.result-commentary {
  margin: -2px 0 14px;
  padding: 9px 12px;
  border-radius: 10px;
  background: rgba(44, 36, 22, 0.08);
  color: #2c2416;
  font-size: 13px;
  line-height: 1.45;
}

/* 详情行 */
.card-details {
  background: rgba(44, 36, 22, 0.06);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 20px;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid rgba(44, 36, 22, 0.1);
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 14px;
  color: #8b7f72;
}

.detail-value {
  font-size: 15px;
  font-weight: 500;
  color: #2c2416;
}

.detail-value.star {
  color: #c9a84c;
}

.detail-value.cost {
  color: #c44a3a;
}

.detail-value.distance {
  color: #8b6d3f;
}

.detail-value.category {
  color: #666;
  font-size: 13px;
}

/* 卡片按钮 */
